{
  "name": "imperio-casino",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && mkdir -p build/server/db && cp -r src/lib/server/db/migrations build/server/db/migrations",
    "preview": "vite preview",
    "check": "svelte-kit sync && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate"
  },
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@threlte/core": "^8.5.16",
    "@threlte/extras": "^9.21.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/kit": "^2.69.3",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^26.1.1",
    "@types/three": "^0.184.0",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.5",
    "svelte-check": "^4.7.3",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "cookie": ">=0.7.0 <2"
    }
  }
}
